# ============================================
# Gaming Club — змінні середовища
# Скопіюйте цей файл у .env і заповніть значення
# ============================================

# Секрет для підпису JWT токенів (змініть в production!)
JWT_SECRET=change-me-in-production

# Порт сервера (за замовчуванням 3000)
PORT=3000

# Ім'я головного адміна (за замовчуванням 'bodik')
# Цей юзер автоматично отримає is_admin=1 при першому запуску
INITIAL_ADMIN=bodik

# Turso хмарна БД (якщо не вказано — використовується локальний файл gameclub.db)
# Отримати на: https://turso.tech
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# URL сервера на Render (для keep-alive ping, щоб сервер не засинав)
# Вказувати тільки при деплої на Render
# RENDER_EXTERNAL_URL=https://your-app.onrender.com

# Середовище (production вимагає JWT_SECRET)
# NODE_ENV=production
